DATABASE_URL=mysql+pymysql://root:@localhost:3306/bindl
SECRET_KEY=change-this-to-any-long-random-string-32-chars-min
APP_ENV=development
FRONTEND_URL=http://localhost:3000
BASE_RPC_URL=http://127.0.0.1:7545
CHAIN_ID=1337
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
SIGNER_PRIVATE_KEY=your-ganache-account-private-key
GEMINI_API_KEY=your-gemini-api-key
PROTOCOL_FEE_BPS=200
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# ─── Email Configuration ──────────────────────────────────────────────────────
# OPTION 1: Gmail SMTP (requires app-specific password if 2FA is enabled)
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer" (or your device)
# 3. Generate a 16-character app password
# 4. Use that password below (not your Google password)
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=your-gmail@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# OPTION 2: SendGrid (recommended for production)
# Get API key from https://sendgrid.com and replace below
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.your-api-key-here
# MAIL_FROM=noreply@yourdomain.com
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587

# OPTION 3: Mailgun
# Get SMTP credentials from https://mailgun.com
# MAIL_USERNAME=postmaster@your-domain.mailgun.org
# MAIL_PASSWORD=your-mailgun-password
# MAIL_FROM=noreply@your-domain.mailgun.org
# MAIL_SERVER=smtp.mailgun.org
# MAIL_PORT=587

# Leave email settings empty to disable email notifications (contracts will still work)
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_FROM=
